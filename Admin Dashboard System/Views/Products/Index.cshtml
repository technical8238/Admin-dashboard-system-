@model Admin_Dashboard_System.ViewModels.PaginatedList<Admin_Dashboard_System.ViewModels.ProductViewModel>
@{
    ViewData["Title"] = "Products";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Products Management</h4>
    <div>
        <a asp-action="ExportToExcel" class="btn btn-success me-2">
            <i class="fas fa-file-excel me-2"></i>Export Excel
        </a>
        <a asp-action="ExportToPdf" class="btn btn-danger me-2">
            <i class="fas fa-file-pdf me-2"></i>Export PDF
        </a>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Add Product
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form id="bulkActionForm" method="post">
            <div class="row mb-3">
                <div class="col-md-4">
                    <div class="input-group">
                        <input type="checkbox" id="selectAll" class="form-check-input mt-2 me-2" />
                        <select id="bulkAction" class="form-select">
                            <option value="">Bulk Actions</option>
                            <option value="delete">Delete Selected</option>
                        </select>
                        <button type="button" onclick="executeBulkAction()" class="btn btn-danger">Execute</button>
                    </div>
                </div>
                <div class="col-md-6">
                    <form asp-action="Index" method="get" class="d-flex">
                        <input type="text" name="searchTerm" value="@ViewData["SearchTerm"]" class="form-control me-2" placeholder="Search products..." />
                        <button type="submit" class="btn btn-outline-primary">Search</button>
                        @if (!string.IsNullOrEmpty(ViewData["SearchTerm"]?.ToString()))
                        {
                            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Clear</a>
                        }
                    </form>
                </div>
            </div>

        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th><input type="checkbox" id="selectAllHeader" class="form-check-input select-all-checkbox" /></th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["NameSortParam"]" asp-route-searchTerm="@ViewData["SearchTerm"]" class="text-decoration-none text-dark">
                                Name <i class="fas fa-sort"></i>
                            </a>
                        </th>
                        <th>Description</th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["PriceSortParam"]" asp-route-searchTerm="@ViewData["SearchTerm"]" class="text-decoration-none text-dark">
                                Price <i class="fas fa-sort"></i>
                            </a>
                        </th>
                        <th>Stock</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["DateSortParam"]" asp-route-searchTerm="@ViewData["SearchTerm"]" class="text-decoration-none text-dark">
                                Created Date <i class="fas fa-sort"></i>
                            </a>
                        </th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model)
                    {
                        <tr>
                            <td><input type="checkbox" name="ids" value="@product.Id" class="form-check-input item-checkbox" /></td>
                            <td>
                                <div class="d-flex align-items-center">
                                    @if (!string.IsNullOrEmpty(product.ImageUrl))
                                    {
                                        <img src="@product.ImageUrl" alt="@product.Name" class="rounded me-2" style="width: 40px; height: 40px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div class="rounded me-2 bg-secondary d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                            <i class="fas fa-image text-white"></i>
                                        </div>
                                    }
                                    @product.Name
                                </div>
                            </td>
                            <td>@product.Description</td>
                            <td>$@product.Price.ToString("F2")</td>
                            <td>@product.StockQuantity</td>
                            <td>@product.CategoryName</td>
                            <td>
                                @if (product.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>@product.CreatedDate.ToString("yyyy-MM-dd")</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@product.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        </form>
        
        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Page navigation" class="mt-3">
                <ul class="pagination justify-content-center">
                    @if (Model.HasPreviousPage)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex - 1)" 
                               asp-route-searchTerm="@ViewData["SearchTerm"]" asp-route-sortOrder="@ViewData["CurrentSort"]">Previous</a>
                        </li>
                    }
                    else
                    {
                        <li class="page-item disabled">
                            <span class="page-link">Previous</span>
                        </li>
                    }

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@i" 
                               asp-route-searchTerm="@ViewData["SearchTerm"]" asp-route-sortOrder="@ViewData["CurrentSort"]">@i</a>
                        </li>
                    }

                    @if (Model.HasNextPage)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex + 1)" 
                               asp-route-searchTerm="@ViewData["SearchTerm"]" asp-route-sortOrder="@ViewData["CurrentSort"]">Next</a>
                        </li>
                    }
                    else
                    {
                        <li class="page-item disabled">
                            <span class="page-link">Next</span>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>

@section Scripts {
    <script>
        function executeBulkAction() {
            const action = document.getElementById('bulkAction').value;
            const selectedIds = Array.from(document.querySelectorAll('.item-checkbox:checked')).map(cb => cb.value);
            
            if (selectedIds.length === 0) {
                alert('Please select at least one item.');
                return;
            }
            
            if (action === 'delete') {
                if (confirm(`Are you sure you want to delete ${selectedIds.length} item(s)?`)) {
                    const form = document.createElement('form');
                    form.method = 'post';
                    form.action = '@Url.Action("BulkDelete")';
                    
                    selectedIds.forEach(id => {
                        const input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = 'ids';
                        input.value = id;
                        form.appendChild(input);
                    });
                    
                    const token = document.querySelector('input[name="__RequestVerificationToken"]');
                    if (token) {
                        const tokenInput = document.createElement('input');
                        tokenInput.type = 'hidden';
                        tokenInput.name = '__RequestVerificationToken';
                        tokenInput.value = token.value;
                        form.appendChild(tokenInput);
                    }
                    
                    document.body.appendChild(form);
                    form.submit();
                }
            } else {
                alert('Please select an action.');
            }
        }
        
        document.getElementById('selectAll').addEventListener('change', function() {
            document.querySelectorAll('.item-checkbox').forEach(cb => cb.checked = this.checked);
        });
    </script>
}