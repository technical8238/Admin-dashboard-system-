@model Admin_Dashboard_System.ViewModels.PaginatedList<Admin_Dashboard_System.ViewModels.OrderViewModel>
@{
    ViewData["Title"] = "Orders";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Orders Management</h4>
    <div>
        <a asp-action="ExportToExcel" class="btn btn-success me-2">
            <i class="fas fa-file-excel me-2"></i>Export Excel
        </a>
        <a asp-action="ExportToPdf" class="btn btn-danger">
            <i class="fas fa-file-pdf me-2"></i>Export PDF
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>
                        <a asp-action="Index" asp-route-sortOrder="@ViewData["IdSortParam"]">Order ID</a>
                    </th>
                    <th>Customer</th>
                    <th>Email</th>
                    <th>
                        <a asp-action="Index" asp-route-sortOrder="@ViewData["AmountSortParam"]">Total Amount</a>
                    </th>
                    <th>
                        <a asp-action="Index" asp-route-sortOrder="@ViewData["StatusSortParam"]">Status</a>
                    </th>
                    <th>Items</th>
                    <th>
                        <a asp-action="Index" asp-route-sortOrder="@ViewData["DateSortParam"]">Order Date</a>
                    </th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>#@order.Id</td>
                        <td>@order.UserName</td>
                        <td>@order.UserEmail</td>
                        <td>$@order.TotalAmount.ToString("N2")</td>
                        <td>
                            <span class="badge bg-@(order.Status == "Pending" ? "warning" : order.Status == "Processing" ? "info" : order.Status == "Shipped" ? "primary" : order.Status == "Delivered" ? "success" : "danger")">@order.Status</span>
                        </td>
                        <td>@order.ItemCount</td>
                        <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-info">
                                <i class="fas fa-eye"></i>
                            </a>
                            <div class="dropdown d-inline">
                                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-cog"></i>
                                </button>
                                <ul class="dropdown-menu">
                                    <li>
                                        <form asp-action="UpdateStatus" asp-route-id="@order.Id" method="post" class="d-inline">
                                            <input type="hidden" name="status" value="Processing" />
                                            <button type="submit" class="dropdown-item">Mark as Processing</button>
                                        </form>
                                    </li>
                                    <li>
                                        <form asp-action="UpdateStatus" asp-route-id="@order.Id" method="post" class="d-inline">
                                            <input type="hidden" name="status" value="Shipped" />
                                            <button type="submit" class="dropdown-item">Mark as Shipped</button>
                                        </form>
                                    </li>
                                    <li>
                                        <form asp-action="UpdateStatus" asp-route-id="@order.Id" method="post" class="d-inline">
                                            <input type="hidden" name="status" value="Delivered" />
                                            <button type="submit" class="dropdown-item">Mark as Delivered</button>
                                        </form>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-action="UpdateStatus" asp-route-id="@order.Id" method="post" class="d-inline">
                                            <input type="hidden" name="status" value="Cancelled" />
                                            <button type="submit" class="dropdown-item text-danger">Cancel Order</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                            <form asp-action="Delete" asp-route-id="@order.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Are you sure you want to delete this order?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        
        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Page navigation" class="mt-3">
                <ul class="pagination justify-content-center">
                    @if (Model.HasPreviousPage)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex - 1)" asp-route-sortOrder="@ViewData["CurrentSort"]"
                               asp-route-searchTerm="@ViewData["SearchTerm"]" asp-route-statusFilter="@ViewData["StatusFilter"]" asp-route-startDate="@ViewData["StartDate"]" asp-route-endDate="@ViewData["EndDate"]">Previous</a>
                        </li>
                    }
                    else
                    {
                        <li class="page-item disabled">
                            <span class="page-link">Previous</span>
                        </li>
                    }

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-sortOrder="@ViewData["CurrentSort"]"
                               asp-route-searchTerm="@ViewData["SearchTerm"]" asp-route-statusFilter="@ViewData["StatusFilter"]" asp-route-startDate="@ViewData["StartDate"]" asp-route-endDate="@ViewData["EndDate"]">@i</a>
                        </li>
                    }

                    @if (Model.HasNextPage)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex + 1)" asp-route-sortOrder="@ViewData["CurrentSort"]"
                               asp-route-searchTerm="@ViewData["SearchTerm"]" asp-route-statusFilter="@ViewData["StatusFilter"]" asp-route-startDate="@ViewData["StartDate"]" asp-route-endDate="@ViewData["EndDate"]">Next</a>
                        </li>
                    }
                    else
                    {
                        <li class="page-item disabled">
                            <span class="page-link">Next</span>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>