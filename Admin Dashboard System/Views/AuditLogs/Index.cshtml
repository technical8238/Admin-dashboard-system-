@model IEnumerable<Admin_Dashboard_System.Models.AuditLog>
@{
    ViewData["Title"] = "Audit Logs";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Audit Logs</h4>
</div>

<div class="card">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-3">
                <form asp-action="Index" method="get" class="d-flex">
                    <input type="text" name="userNameFilter" value="@ViewData["UserNameFilter"]" class="form-control me-2" placeholder="Search by user..." />
                    <button type="submit" class="btn btn-outline-primary">Search</button>
                    @if (!string.IsNullOrEmpty(ViewData["UserNameFilter"]?.ToString()) || !string.IsNullOrEmpty(ViewData["EntityTypeFilter"]?.ToString()) || ViewData["StartDate"] != null || ViewData["EndDate"] != null)
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Clear</a>
                    }
                </form>
            </div>
            <div class="col-md-2">
                <select name="entityTypeFilter" class="form-select" onchange="this.form.submit()">
                    <option value="">All Entities</option>
                    <option value="User" selected="@(ViewData["EntityTypeFilter"]?.ToString() == "User")">User</option>
                    <option value="Product" selected="@(ViewData["EntityTypeFilter"]?.ToString() == "Product")">Product</option>
                    <option value="Category" selected="@(ViewData["EntityTypeFilter"]?.ToString() == "Category")">Category</option>
                    <option value="Order" selected="@(ViewData["EntityTypeFilter"]?.ToString() == "Order")">Order</option>
                </select>
            </div>
            <div class="col-md-2">
                <input type="date" name="startDate" value="@ViewData["StartDate"]" class="form-control" placeholder="Start Date" onchange="this.form.submit()" />
            </div>
            <div class="col-md-2">
                <input type="date" name="endDate" value="@ViewData["EndDate"]" class="form-control" placeholder="End Date" onchange="this.form.submit()" />
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Date/Time</th>
                        <th>User</th>
                        <th>Action</th>
                        <th>Entity Type</th>
                        <th>Entity ID</th>
                        <th>Description</th>
                        <th>IP Address</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td>@log.CreatedDate.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>@log.UserName</td>
                            <td>
                                <span class="badge bg-@(log.Action == "Create" ? "success" : log.Action == "Update" ? "warning" : log.Action == "Delete" ? "danger" : "info")">@log.Action</span>
                            </td>
                            <td>@log.EntityType</td>
                            <td>@log.EntityId</td>
                            <td>@log.Description</td>
                            <td>@log.IpAddress</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
