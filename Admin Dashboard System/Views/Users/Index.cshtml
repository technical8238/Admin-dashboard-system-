@model Admin_Dashboard_System.ViewModels.PaginatedList<Admin_Dashboard_System.ViewModels.UserViewModel>
@{
    ViewData["Title"] = "Users";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Users Management</h4>
    <div>
        <a asp-action="ExportToExcel" class="btn btn-success me-2">
            <i class="fas fa-file-excel me-2"></i>Export Excel
        </a>
        <a asp-action="ExportToPdf" class="btn btn-danger me-2">
            <i class="fas fa-file-pdf me-2"></i>Export PDF
        </a>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Add User
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["NameSortParam"]" class="text-decoration-none text-dark">
                                Name <i class="fas fa-sort"></i>
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["EmailSortParam"]" class="text-decoration-none text-dark">
                                Email <i class="fas fa-sort"></i>
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["RoleSortParam"]" class="text-decoration-none text-dark">
                                Role <i class="fas fa-sort"></i>
                            </a>
                        </th>
                        <th>Status</th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["DateSortParam"]" class="text-decoration-none text-dark">
                                Created Date <i class="fas fa-sort"></i>
                            </a>
                        </th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.FirstName @user.LastName</td>
                            <td>@user.Email</td>
                            <td>
                                <span class="badge bg-@(user.Role == "Admin" ? "danger" : user.Role == "Manager" ? "warning" : "secondary")">@user.Role</span>
                            </td>
                            <td>
                                <span class="badge bg-@(user.IsActive ? "success" : "danger")">@(user.IsActive ? "Active" : "Inactive")</span>
                            </td>
                            <td>@user.CreatedDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@user.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Are you sure you want to delete this user?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Page navigation" class="mt-3">
                <ul class="pagination justify-content-center">
                    @if (Model.HasPreviousPage)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex - 1)" asp-route-sortOrder="@ViewData["CurrentSort"]"
                               asp-route-searchTerm="@ViewData["SearchTerm"]" asp-route-roleFilter="@ViewData["RoleFilter"]" asp-route-statusFilter="@ViewData["StatusFilter"]">Previous</a>
                        </li>
                    }
                    else
                    {
                        <li class="page-item disabled">
                            <span class="page-link">Previous</span>
                        </li>
                    }

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        </li>
                    }

                    @if (Model.HasNextPage)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex + 1)" asp-route-sortOrder="@ViewData["CurrentSort"]"
                               asp-route-searchTerm="@ViewData["SearchTerm"]" asp-route-roleFilter="@ViewData["RoleFilter"]" asp-route-statusFilter="@ViewData["StatusFilter"]">Next</a>
                        </li>
                    }
                    else
                    {
                        <li class="page-item disabled">
                            <span class="page-link">Next</span>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>